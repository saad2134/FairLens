rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read for prototype
      allow read: if true;
      // Authenticated write only, max 10MB
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
    }
  }
}